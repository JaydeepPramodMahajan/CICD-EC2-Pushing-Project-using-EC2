pipeline{
    agent any

    stages{
        stage("Checking python version"){
            steps{
                bat "python --version"
            }
        }
        stage("Run Directly"){
            steps{
                bat "python index.py"
            }
        }
    }
    post{
        always{
            echo "========always========"
        }
        success{
            echo "========pipeline executed successfully ========"
        }
        failure{
            echo "========pipeline execution failed========"
        }
    }
}